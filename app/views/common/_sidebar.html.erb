<div>
  <h3>Etiquetas</h3>

  <%= form_with(url: entries_path, method: :get, data: { controller: "tags" }) do |form| %>
    <div class="tags-filter">
      <%= form.collection_checkboxes(:tags, Tag.all, :name, :name, include_hidden: false, checked: params[:tags]) do |b| %>
        <%= b.label do %>
          <%= b.checkbox data: { action: "change->tags#submit" } %>
          <span><%= b.text %></span>
        <% end %>
      <% end %>
    </div>
    <%= form.submit "Filtrar", name: nil, data: { tags_target: "button" } %>
  <% end %>
</div>

